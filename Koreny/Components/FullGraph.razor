@using System.Text
@using Koreny.Models
@using Koreny.Services

@inject FamilyGraphLayoutService LayoutService

@* Positions from GraphShape Sugiyama via FamilyGraphLayoutService. *@

@code {
    public const double NODE_WIDTH = 160;
    public const double NODE_HEIGHT = 56;
    public const double H_GAP = 24;
    public const double V_GAP = 80;

    private const double V_CONNECTOR_GAP = V_GAP / 2.0;

    private const double NameLineY = 22;
    private const double LifespanLineY = 42;
    private const int MaxNameChars = 26;

    [Parameter]
    public GedcomDocument? Document { get; set; }

    public string RenderToSvg()
    {
        return RenderToSvg(Document, LayoutService);
    }

    public static string RenderToSvg(GedcomDocument? document, FamilyGraphLayoutService layoutService)
    {
        if (document is null || document.Individuals.Count == 0)
        {
            return EmptySvg("No individuals.");
        }

        var raw = layoutService.ComputeLayout(document);
        if (raw.Count == 0)
        {
            return EmptySvg("No layout.");
        }

        var positions = new Dictionary<string, (double X, double Y)>(StringComparer.Ordinal);
        foreach (var kv in raw)
        {
            positions[kv.Key] = kv.Value;
        }

        ApplyPartnerSeparation(document, positions);
        ApplyGenerationOverlapRemoval(positions);
        RecenterLayoutPositions(positions);

        var gen = new Dictionary<string, int>(StringComparer.Ordinal);
        var childIds = new HashSet<string>(StringComparer.Ordinal);
        foreach (var f in document.Families)
        {
            foreach (var c in f.ChildrenIds)
            {
                childIds.Add(c);
            }
        }

        foreach (var ind in document.Individuals)
        {
            if (!childIds.Contains(ind.Id))
            {
                gen[ind.Id] = 0;
            }
        }

        if (gen.Count == 0)
        {
            return EmptySvg("No root persons (everyone is a child).");
        }

        PropagateGenerations(document, gen);
        foreach (var ind in document.Individuals)
        {
            if (!gen.ContainsKey(ind.Id))
            {
                gen[ind.Id] = 0;
            }
        }

        var totalW = positions.Values.Max(p => p.X + NODE_WIDTH) + H_GAP;
        var totalH = positions.Values.Max(p => p.Y + NODE_HEIGHT) + V_GAP;

        var boxes = new List<PersonBox>();
        foreach (var ind in document.Individuals)
        {
            if (!positions.TryGetValue(ind.Id, out var p))
            {
                continue;
            }

            boxes.Add(MakeBox(document, ind.Id, p.X + NODE_WIDTH * 0.5, p.Y));
        }

        var segments = new List<LineSeg>();
        foreach (var f in document.Families)
        {
            AddFamilyConnectors(f, gen, positions, segments);
        }

        return BuildSvgXml(totalW, totalH, segments, boxes);
    }

    /// <summary>Separate spouses that Sugiyama placed too close; ripple shift keeps global order.</summary>
    private static void ApplyPartnerSeparation(GedcomDocument document, Dictionary<string, (double X, double Y)> positions)
    {
        var minPitch = NODE_WIDTH + H_GAP;
        foreach (var fam in document.Families.OrderBy(f => f.Id, StringComparer.Ordinal))
        {
            var h = fam.HusbandId;
            var wif = fam.WifeId;
            if (string.IsNullOrEmpty(h) || string.IsNullOrEmpty(wif))
            {
                continue;
            }

            if (!positions.TryGetValue(h, out var pH) || !positions.TryGetValue(wif, out var pW))
            {
                continue;
            }

            string leftId;
            string rightId;
            double oldXLeft;
            double oldXRight;
            if (pH.X <= pW.X)
            {
                leftId = h;
                rightId = wif;
                oldXLeft = pH.X;
                oldXRight = pW.X;
            }
            else
            {
                leftId = wif;
                rightId = h;
                oldXLeft = pW.X;
                oldXRight = pH.X;
            }

            if (oldXRight - oldXLeft >= minPitch - 1e-9)
            {
                continue;
            }

            var targetXRight = oldXLeft + minPitch;
            var delta = targetXRight - oldXRight;

            foreach (var id in positions.Keys.ToList())
            {
                if (id == rightId)
                {
                    continue;
                }

                var (x, y) = positions[id];
                if (x > oldXRight)
                {
                    positions[id] = (x + delta, y);
                }
            }

            var yR = positions[rightId].Y;
            positions[rightId] = (targetXRight, yR);
        }
    }

    /// <summary>Same-row clusters (Y within 4px); sweep X until minimum spacing holds.</summary>
    private static void ApplyGenerationOverlapRemoval(Dictionary<string, (double X, double Y)> positions)
    {
        if (positions.Count == 0)
        {
            return;
        }

        var minPitch = NODE_WIDTH + H_GAP;
        var sortedByY = positions.Keys.OrderBy(id => positions[id].Y).ToList();
        var idx = 0;
        while (idx < sortedByY.Count)
        {
            var groupStartY = positions[sortedByY[idx]].Y;
            var next = idx;
            while (next < sortedByY.Count && positions[sortedByY[next]].Y - groupStartY <= 4.0)
            {
                next++;
            }

            var rowIds = sortedByY.Skip(idx).Take(next - idx).ToList();
            var guard = 0;
            var changed = true;
            while (changed && guard++ < rowIds.Count * 8)
            {
                changed = false;
                rowIds.Sort((a, b) => positions[a].X.CompareTo(positions[b].X));
                for (var k = 0; k < rowIds.Count - 1; k++)
                {
                    var xk = positions[rowIds[k]].X;
                    var xk1 = positions[rowIds[k + 1]].X;
                    if (xk1 - xk < minPitch - 1e-9)
                    {
                        var delta = minPitch - (xk1 - xk);
                        for (var m = k + 1; m < rowIds.Count; m++)
                        {
                            var id = rowIds[m];
                            var (x, y) = positions[id];
                            positions[id] = (x + delta, y);
                        }

                        changed = true;
                    }
                }
            }

            idx = next;
        }
    }

    /// <summary>Align left margin to H_GAP; align top to Y=0 for predictable viewBox.</summary>
    private static void RecenterLayoutPositions(Dictionary<string, (double X, double Y)> positions)
    {
        if (positions.Count == 0)
        {
            return;
        }

        var minX = positions.Values.Min(p => p.X);
        var minY = positions.Values.Min(p => p.Y);
        var dx = H_GAP - minX;
        var dy = -minY;
        foreach (var id in positions.Keys.ToList())
        {
            var (x, y) = positions[id];
            positions[id] = (x + dx, y + dy);
        }
    }

    private static void PropagateGenerations(GedcomDocument document, Dictionary<string, int> gen)
    {
        var changed = true;
        var guard = 0;
        while (changed && guard++ < document.Individuals.Count + document.Families.Count + 10)
        {
            changed = false;
            foreach (var fam in document.Families)
            {
                var pg = -1;
                if (!string.IsNullOrEmpty(fam.HusbandId) && gen.TryGetValue(fam.HusbandId, out var gh))
                {
                    pg = Math.Max(pg, gh);
                }

                if (!string.IsNullOrEmpty(fam.WifeId) && gen.TryGetValue(fam.WifeId, out var gw))
                {
                    pg = Math.Max(pg, gw);
                }

                if (pg < 0)
                {
                    continue;
                }

                foreach (var c in fam.ChildrenIds)
                {
                    var ng = pg + 1;
                    if (!gen.TryGetValue(c, out var old) || old < ng)
                    {
                        gen[c] = ng;
                        changed = true;
                    }
                }
            }
        }
    }

    /// <summary>Uses only final layout positions (post-processed); one pass after fixup.</summary>
    private static void AddFamilyConnectors(
        GedcomFamily f,
        Dictionary<string, int> gen,
        Dictionary<string, (double X, double Y)> positions,
        List<LineSeg> segments)
    {
        var kids = f.ChildrenIds.Where(c => gen.ContainsKey(c) && positions.ContainsKey(c)).ToList();
        if (kids.Count == 0)
        {
            return;
        }

        var childrenLineY = kids.Min(id => positions[id].Y) - V_CONNECTOR_GAP;

        var pgH = !string.IsNullOrEmpty(f.HusbandId) && gen.TryGetValue(f.HusbandId!, out var gh) ? gh : (int?)null;
        var pgW = !string.IsNullOrEmpty(f.WifeId) && gen.TryGetValue(f.WifeId!, out var gw) ? gw : (int?)null;

        var h = f.HusbandId;
        var wif = f.WifeId;

        if (!string.IsNullOrEmpty(h) && !string.IsNullOrEmpty(wif) && pgH == pgW && pgH.HasValue
            && positions.ContainsKey(h) && positions.ContainsKey(wif))
        {
            var pH = positions[h];
            var pW = positions[wif];
            var leftId = pH.X <= pW.X ? h : wif;
            var rightId = pH.X <= pW.X ? wif : h;
            var left = positions[leftId];
            var right = positions[rightId];

            var coupleLineY = left.Y + NODE_HEIGHT * 0.5;
            var xCouple1 = left.X + NODE_WIDTH;
            var xCouple2 = right.X;
            segments.Add(new LineSeg { X1 = xCouple1, Y1 = coupleLineY, X2 = xCouple2, Y2 = coupleLineY });

            var coupleMidX = (left.X + NODE_WIDTH + right.X) * 0.5;

            segments.Add(new LineSeg { X1 = coupleMidX, Y1 = coupleLineY, X2 = coupleMidX, Y2 = childrenLineY });

            var kidsByX = kids.OrderBy(c => positions[c].X).ToList();
            var leftmost = kidsByX[0];
            var rightmost = kidsByX[^1];
            var xHoriz1 = positions[leftmost].X + NODE_WIDTH * 0.5;
            var xHoriz2 = positions[rightmost].X + NODE_WIDTH * 0.5;
            segments.Add(new LineSeg { X1 = xHoriz1, Y1 = childrenLineY, X2 = xHoriz2, Y2 = childrenLineY });

            foreach (var c in kids)
            {
                var pc = positions[c];
                var childCenterX = pc.X + NODE_WIDTH * 0.5;
                var y1 = childrenLineY;
                var y2 = pc.Y;
                if (Math.Abs(y2 - y1) > 1e-6)
                {
                    segments.Add(new LineSeg { X1 = childCenterX, Y1 = y1, X2 = childCenterX, Y2 = y2 });
                }
            }

            return;
        }

        string? parent = null;
        int? pg = null;
        if (!string.IsNullOrEmpty(h) && positions.ContainsKey(h) && pgH.HasValue)
        {
            parent = h;
            pg = pgH;
        }
        else if (!string.IsNullOrEmpty(wif) && positions.ContainsKey(wif) && pgW.HasValue)
        {
            parent = wif;
            pg = pgW;
        }
        else if (!string.IsNullOrEmpty(h) && positions.ContainsKey(h))
        {
            parent = h;
            pg = gen.GetValueOrDefault(h);
        }
        else if (!string.IsNullOrEmpty(wif) && positions.ContainsKey(wif))
        {
            parent = wif;
            pg = gen.GetValueOrDefault(wif);
        }

        if (parent is null || !pg.HasValue)
        {
            return;
        }

        var pParent = positions[parent];
        var cx = pParent.X + NODE_WIDTH * 0.5;
        var bottomY = pParent.Y + NODE_HEIGHT;

        segments.Add(new LineSeg { X1 = cx, Y1 = bottomY, X2 = cx, Y2 = childrenLineY });

        foreach (var c in kids)
        {
            var ccx = positions[c].X + NODE_WIDTH * 0.5;
            var childY = positions[c].Y;
            if (Math.Abs(ccx - cx) > NODE_WIDTH)
            {
                var routeY = pParent.Y - V_GAP * 0.5;
                if (routeY < 0)
                {
                    routeY = childrenLineY;
                }

                segments.Add(new LineSeg { X1 = cx, Y1 = childrenLineY, X2 = cx, Y2 = routeY });
                segments.Add(new LineSeg { X1 = cx, Y1 = routeY, X2 = ccx, Y2 = routeY });
                segments.Add(new LineSeg { X1 = ccx, Y1 = routeY, X2 = ccx, Y2 = childY });
            }
            else if (Math.Abs(ccx - cx) > 0.01)
            {
                segments.Add(new LineSeg { X1 = cx, Y1 = childrenLineY, X2 = ccx, Y2 = childrenLineY });
                segments.Add(new LineSeg { X1 = ccx, Y1 = childrenLineY, X2 = ccx, Y2 = childY });
            }
            else
            {
                segments.Add(new LineSeg { X1 = ccx, Y1 = childrenLineY, X2 = ccx, Y2 = childY });
            }
        }
    }

    private static string N(double v) => v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private static string EmptySvg(string message)
    {
        var e = SvgEscape(message);
        return $"""<svg xmlns="http://www.w3.org/2000/svg" width="320" height="80" viewBox="0 0 320 80"><text x="160" y="44" text-anchor="middle" font-size="13" fill="#333">{e}</text></svg>""";
    }

    private static string BuildSvgXml(double width, double height, List<LineSeg> segments, List<PersonBox> boxes)
    {
        var sb = new StringBuilder();
        sb.Append($"""<svg xmlns="http://www.w3.org/2000/svg" width="{N(width)}" height="{N(height)}" viewBox="0 0 {N(width)} {N(height)}">""");
        sb.Append($"<rect x=\"0\" y=\"0\" width=\"{N(width)}\" height=\"{N(height)}\" fill=\"white\" />");
        sb.Append("""<g stroke="#2a2a2a" stroke-width="1.5" fill="none">""");
        foreach (var seg in segments)
        {
            sb.Append($"<line x1=\"{N(seg.X1)}\" y1=\"{N(seg.Y1)}\" x2=\"{N(seg.X2)}\" y2=\"{N(seg.Y2)}\" />");
        }

        sb.Append("</g><g>");
        foreach (var box in boxes)
        {
            var left = box.CenterX - NODE_WIDTH * 0.5;
            var top = box.Y;
            sb.Append($"<rect x=\"{N(left)}\" y=\"{N(top)}\" width=\"{N(NODE_WIDTH)}\" height=\"{N(NODE_HEIGHT)}\" fill=\"{box.Fill}\" stroke=\"#1a1a1a\" />");
            sb.Append($"<text x=\"{N(box.CenterX)}\" y=\"{N(top + NameLineY)}\" text-anchor=\"middle\" font-size=\"13\" fill=\"white\">{SvgEscape(box.FullName)}</text>");
            sb.Append($"<text x=\"{N(box.CenterX)}\" y=\"{N(top + LifespanLineY)}\" text-anchor=\"middle\" font-size=\"13\" fill=\"white\">{SvgEscape(box.Lifespan)}</text>");
        }

        sb.Append("</g></svg>");
        return sb.ToString();
    }

    private static PersonBox MakeBox(GedcomDocument document, string id, double centerX, double y)
    {
        var ind = FindIndividual(document, id);
        var name = ind?.FullName ?? id;
        return new PersonBox
        {
            CenterX = centerX,
            Y = y,
            FullName = Truncate(string.IsNullOrWhiteSpace(name) ? id : name),
            Lifespan = FormatLife(ind),
            Fill = FillFor(ind),
        };
    }

    private static string FillFor(GedcomIndividual? i)
    {
        if (i?.Sex == "M")
        {
            return "#4A7FB5";
        }

        if (i?.Sex == "F")
        {
            return "#9B2335";
        }

        return "#888780";
    }

    private static string FormatLife(GedcomIndividual? i)
    {
        if (i is null)
        {
            return "?";
        }

        var b = i.Birth?.ParsedYear;
        var d = i.Death?.ParsedYear;
        if (b is not null && d is not null)
        {
            return $"{b}–{d}";
        }

        if (b is not null)
        {
            return $"{b}–";
        }

        if (d is not null)
        {
            return $"–{d}";
        }

        return "?";
    }

    private static string Truncate(string s)
    {
        if (s.Length <= MaxNameChars)
        {
            return s;
        }

        return s[..(MaxNameChars - 1)] + "…";
    }

    private static string SvgEscape(string s)
    {
        return s
            .Replace("&", "&amp;", StringComparison.Ordinal)
            .Replace("<", "&lt;", StringComparison.Ordinal)
            .Replace(">", "&gt;", StringComparison.Ordinal)
            .Replace("\"", "&quot;", StringComparison.Ordinal)
            .Replace("'", "&apos;", StringComparison.Ordinal);
    }

    private static GedcomIndividual? FindIndividual(GedcomDocument doc, string id)
    {
        foreach (var i in doc.Individuals)
        {
            if (i.Id == id)
            {
                return i;
            }
        }

        return null;
    }

    private sealed class PersonBox
    {
        public double CenterX { get; init; }
        public double Y { get; init; }
        public required string FullName { get; init; }
        public required string Lifespan { get; init; }
        public required string Fill { get; init; }
    }

    private sealed class LineSeg
    {
        public double X1 { get; init; }
        public double Y1 { get; init; }
        public double X2 { get; init; }
        public double Y2 { get; init; }
    }
}
